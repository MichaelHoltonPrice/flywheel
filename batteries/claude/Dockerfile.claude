FROM python:3.12-slim

# Install Node.js 22 (required for Claude Code CLI).
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
       ca-certificates curl gnupg iptables \
    && mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
       | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_22.x nodistro main" \
       > /etc/apt/sources.list.d/nodesource.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# The Agents SDK spawns the Claude Code CLI as a subprocess.
RUN npm install -g @anthropic-ai/claude-code

# Install the Agents SDK, HTTP client, and image rendering deps.
# NOTE: We intentionally do NOT install arc-agi here to prevent
# information leakage — it includes the game engine, which would
# let agents inspect game mechanics directly.
RUN pip install claude-agent-sdk httpx mcp Pillow numpy

# Copy the agent runner and built-in MCP server scripts.
# Project-specific MCP servers are mounted at runtime.
COPY agent_runner.py /app/agent_runner.py
COPY eval_mcp_server.py /app/eval_mcp_server.py
COPY entrypoint.sh /app/entrypoint.sh

# Claude Code refuses --dangerously-skip-permissions as root.
RUN useradd -m claude \
    && mkdir -p /home/claude/.claude /workspace \
    && chown -R claude:claude /home/claude /workspace /app \
    && chmod +x /app/entrypoint.sh

# Don't set USER here — entrypoint runs as root to configure
# iptables, then drops to claude via su.
WORKDIR /workspace

ENTRYPOINT ["/app/entrypoint.sh"]
